{
  "name": "seder-media-organizer",
  "version": "1.0.0",
  "description": "Media Asset Organizer for VJs - סדר מדיה",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.seder.media-organizer",
    "productName": "Seder",
    "copyright": "Copyright © 2026",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "src/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "Seder"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "author": "zuribar",
  "license": "MIT"
}
